# Gemini API Key（免費）
# 申請：https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key（免費，無地區限制）
# 申請：https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenWeatherMap API Key（免費，1000次/天）
# 申請：https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# newsdata.io API Key（免費，200次/天）
# 申請：https://newsdata.io/
NEWSDATA_API_KEY=your_newsdata_api_key_here

# Gmail 設定（使用 App Password，不是你的登入密碼）
# 教學：Google 帳號 > 安全性 > 兩步驟驗證 > 應用程式密碼
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# 收件人（可以填自己的 email）
TO_EMAIL=your_email@gmail.com
